{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "2s",
  "timezone": "browser",
  "title": "Coupon Concurrency Lab",
  "uid": "coupon-lab",
  "schemaVersion": 39,
  "tags": ["coupon", "concurrency"],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "TPS (server-side, by status)  — 진단용. 판정은 k6",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{uri=~\"/api/.*\"}[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP latency (server-side p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "targets": [
        {
          "refId": "P50",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{uri=~\"/api/.*\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "P95",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{uri=~\"/api/.*\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "P99",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{uri=~\"/api/.*\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "HikariCP connections  ← 2단계(비관락) 병목: pending 급등 = 풀 고갈",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "ACTIVE",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active",
          "legendFormat": "active"
        },
        {
          "refId": "IDLE",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_idle",
          "legendFormat": "idle"
        },
        {
          "refId": "PENDING",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pending (풀 대기)"
        },
        {
          "refId": "MAX",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_max",
          "legendFormat": "max (풀 크기)"
        }
      ]
    },
    {
      "id": 4,
      "title": "Hikari connection acquire time (max) — 커넥션 얻으려고 기다린 시간",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_acquire_seconds_max",
          "legendFormat": "acquire max"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(hikaricp_connections_usage_seconds_sum[$__rate_interval]) / clamp_min(rate(hikaricp_connections_usage_seconds_count[$__rate_interval]), 1)",
          "legendFormat": "usage avg"
        }
      ]
    },
    {
      "id": 5,
      "title": "Tomcat threads (busy vs max) — 웹 스레드 포화 여부",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "BUSY",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "tomcat_threads_busy_threads",
          "legendFormat": "busy"
        },
        {
          "refId": "CUR",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "tomcat_threads_current_threads",
          "legendFormat": "current"
        },
        {
          "refId": "MAX",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "tomcat_threads_config_max_threads",
          "legendFormat": "config max"
        }
      ]
    },
    {
      "id": 6,
      "title": "MySQL threads running — DB가 동시에 처리 중인 쿼리 수",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "RUN",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mysql_global_status_threads_running",
          "legendFormat": "threads_running"
        },
        {
          "refId": "CONN",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mysql_global_status_threads_connected",
          "legendFormat": "threads_connected"
        }
      ]
    },
    {
      "id": 7,
      "title": "InnoDB row locks  ← 3~4단계: 한 row 직렬화의 정체",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "CUR",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mysql_global_status_innodb_row_lock_current_waits",
          "legendFormat": "현재 락 대기 중"
        },
        {
          "refId": "RATE",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(mysql_global_status_innodb_row_lock_waits[$__rate_interval])",
          "legendFormat": "락 대기 발생율/s"
        }
      ]
    },
    {
      "id": 8,
      "title": "InnoDB row lock 평균 대기시간 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(mysql_global_status_innodb_row_lock_time[$__rate_interval]) / clamp_min(rate(mysql_global_status_innodb_row_lock_waits[$__rate_interval]), 1)",
          "legendFormat": "avg wait (ms)"
        }
      ]
    }
  ]
}
